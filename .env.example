PORT=9119
NODE_ENV=production
MEMPOOL_SPACE_WS_URL=wss://mempool.space/api/v1/ws
MEMPOOL_SPACE_RECONNECT_MS=1000
MEMPOOL_SPACE_STALE_MS=30000
MEMPOOL_SPACE_MEMPOOL_POLL_INTERVAL_MS=5000
MEMPOOL_KNOTS_HTTP_BASE=https://your-private-upstream.example.com
MEMPOOL_KNOTS_HTTP_POLL_INTERVAL_MS=1000
# Supabase Transaction pooler recommended for Docker/Portainer and IPv4-only servers.
# The scraper can parse passwords copied in bracketed/raw form from the dashboard.
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-your-region.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
JOHOE_BASE_URL=https://johoe.jochen-hoenicke.de/queue/2
JOHOE_NETWORK=btc
JOHOE_POLL_INTERVAL_MS=60000
JOHOE_STALE_MS=180000
JOHOE_LOOKBACK_SECONDS=600
JOHOE_LOOKAHEAD_SECONDS=600
JOHOE_BOOTSTRAP_ENABLED=true
JOHOE_BOOTSTRAP_RANGE=all
JOHOE_MAX_HISTORY_POINTS=1440
JOHOE_HISTORY_LIMIT_DEFAULT=1440
JOHOE_DB_ENABLED=true
JOHOE_DB_SSL=true
JOHOE_FORWARD_ENABLED=false
JOHOE_FORWARD_URL=
JOHOE_FORWARD_TOKEN=
JOHOE_FORWARD_BATCH_SIZE=10
JOHOE_FORWARD_INTERVAL_MS=15000
JOHOE_FORWARD_TIMEOUT_MS=10000
HTTPS_REDIRECT_HOST=api.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
SCRAPE_REFRESH_TOKEN=change-this-to-a-long-random-secret
